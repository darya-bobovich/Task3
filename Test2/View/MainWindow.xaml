<Window x:Class="Test2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Test2.ViewModels"
        xmlns:local="clr-namespace:Test2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Canvas Margin="-6,38,6,408">
            <Button x:Name="Button1" Width="150" Height="30" Command="{Binding ImportCommand}" Content="Импорт" FontSize="13"
                    Canvas.Left="88" Canvas.Top="37" />
            <Button x:Name="Button2" Width="150" Height="30"   Command="{Binding ExportCommand}" Content="Экспорт в XML" FontSize="13"
                    Canvas.Left="522" Canvas.Top="37" />
        </Canvas>
        <DataGrid ItemsSource="{Binding Tasks}" AutoGenerateColumns="True" Margin="80,137,99,15"/>
    </Grid>
</Window>